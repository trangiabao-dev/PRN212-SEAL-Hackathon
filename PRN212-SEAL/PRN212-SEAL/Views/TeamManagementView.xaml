<UserControl x:Class="PRN212_SEAL.Views.TeamManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PRN212_SEAL.Views"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="750"
             Loaded="UserControl_Loaded">
    <Grid Background="#F5F7FA">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Width="680" Margin="30">
                <TextBlock Text="QUẢN LÝ TEAM HACKATHON"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#2C3E50"
                           TextAlignment="Center"
                           Margin="0,0,0,20" />

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#E74C3C"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,0,0,10" />

                <TextBlock Text="{Binding SuccessMessage}"
                           Foreground="#27AE60"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,0,0,10" />

                <TextBlock Text="Đang xử lý dữ liệu..."
                           Foreground="#3498DB"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Margin="0,0,0,10">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- TẠO TEAM (Ẩn đi khi đã sở hữu Team) -->
                <Border Padding="22"
                        Background="White"
                        BorderBrush="#DDE3E8"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasTeam}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <StackPanel>
                        <TextBlock Text="Đăng Ký Đội Thi Đấu"
                                   FontSize="19"
                                   FontWeight="SemiBold"
                                   Foreground="#34495E"
                                   Margin="0,0,0,15" />

                        <TextBlock Text="Tên Đội Thi:" FontWeight="Medium" Foreground="#34495E" />
                        <TextBox Text="{Binding TeamName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8"
                                 FontSize="14"
                                 Margin="0,5,0,18" />

                        <TextBlock Text="Danh sách thành viên thường (Từ 2 đến 4 người):"
                                   FontWeight="SemiBold"
                                   Foreground="#34495E"
                                   Margin="0,0,0,10" />

                        <ItemsControl ItemsSource="{Binding Members}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox Grid.Column="0"
                                                 Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="8"
                                                 Margin="0,0,8,0"
                                                 ToolTip="Nhập họ và tên thành viên" />

                                        <TextBox Grid.Column="1"
                                                 Text="{Binding StudentCode, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="8"
                                                 Margin="0,0,8,0"
                                                 MaxLength="8"
                                                 ToolTip="Mã SV gồm 2 chữ hoa + 6 chữ số (VD: SE140123)" />

                                        <Button Grid.Column="2"
                                                Content="Xóa"
                                                Command="{Binding DataContext.RemoveMemberCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                CommandParameter="{Binding}"
                                                Background="#E74C3C"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Padding="7" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                            <Button Content="+ Thêm thành viên"
                                    Command="{Binding AddMemberCommand}"
                                    Background="#95A5A6"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Padding="12,8"
                                    Margin="0,0,10,0" />

                            <Button Content="Xác Nhận Tạo Team"
                                    Command="{Binding CreateTeamCommand}"
                                    Background="#2ECC71"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Padding="18,8" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- KHUNG HIỂN THỊ CHI TIẾT TEAM ĐÃ TẠO -->
                <Border Padding="22"
                        Background="White"
                        BorderBrush="#DDE3E8"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasTeam}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <StackPanel>
                        <TextBlock Text="{Binding CurrentTeam.TeamName}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#2C3E50" />

                        <TextBlock Text="{Binding CurrentTeam.CreatedAt, StringFormat='Ngày đăng ký: {0:dd/MM/yyyy HH:mm}'}"
                                   Foreground="#7F8C8D"
                                   Margin="0,4,0,18" />

                        <TextBlock Text="Thành Viên Chính Thức"
                                   FontWeight="SemiBold"
                                   FontSize="16"
                                   Foreground="#34495E"
                                   Margin="0,0,0,10" />

                        <ItemsControl ItemsSource="{Binding CurrentTeam.Members}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#ECF0F1"
                                            BorderThickness="0,0,0,1"
                                            Padding="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="100" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding FullName}" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding StudentCode}" FontSize="14" Foreground="#7F8C8D" VerticalAlignment="Center"/>
                                            <Border Grid.Column="2" 
                                                    Background="#FEF3C7" 
                                                    CornerRadius="4" 
                                                    Padding="6,2" 
                                                    HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLeader}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="LEADER" Foreground="#D97706" FontWeight="Bold" FontSize="11"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
